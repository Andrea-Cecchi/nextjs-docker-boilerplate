generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id
  name          String
  email         String     @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  accounts      Account[]
  favorites     Favorite[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Drug {
  id                    String         @id @db.VarChar(9) // AIC
  activeSubstance       String         // Principio attivo
  referencePackage      String         // Confezione di riferimento
  atc                   String?        // ATC
  brandName             String         // Farmaco
  pack                  String         // Confezione
  holder                String?        // Ditta
  ssnReferencePrice     Decimal?       @db.Decimal(10, 3) // Prezzo riferimento SSN
  publicPrice           Decimal?       @db.Decimal(10, 3) // Prezzo Pubblico
  priceDifference       Decimal?       @db.Decimal(10, 3) // Differenza
  note                  String?        // Nota
  equivalenceGroupCode  String?        // Codice gruppo equivalenza
  favorites             Favorite[]
  priceHistory          PriceHistory[]

  @@map("drug")
}

model PriceHistory {
  id               Int      @id @default(autoincrement())
  drugId           String   @db.VarChar(9)
  date             DateTime @db.Date
  ssnReferencePrice Decimal @db.Decimal(10, 3) // Prezzo riferimento SSN
  publicPrice      Decimal? @db.Decimal(10, 3) // Prezzo pubblico
  drug             Drug     @relation(fields: [drugId], references: [id])

  @@unique([drugId, date])
  @@map("price_history")
}

model Favorite {
  id     Int    @id @default(autoincrement())
  userId String
  drugId String @db.VarChar(9)
  drug   Drug   @relation(fields: [drugId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, drugId])
  @@map("favorite")
}
